+// ---- Memfd backend (NEW — forkd v0.3) -------------------------------------
+
+/// Error type for [`guest_memory_from_memfd`].
+#[derive(Debug, thiserror::Error, displaydoc::Display)]
+pub enum GuestMemoryFromMemfdError {
+    /// Failed to connect to UDS Unix stream: {0}
+    Connect(std::io::Error),
+    /// Failed to receive memfd from handler: {0}
+    RecvFd(vmm_sys_util::errno::Error),
+    /// Handler did not send a memfd (no SCM_RIGHTS fd in handshake)
+    NoFd,
+    /// Failed to build guest memory from memfd: {0}
+    Restore(#[from] MemoryError),
+}
+
+/// Receive a memfd from the handler at `mem_uds_path` and use it as
+/// MAP_PRIVATE-backing for guest RAM.
+///
+/// Wire format (handler → firecracker, single sendmsg):
+///   - Payload: empty (or, in future, a JSON descriptor for sanity-checking
+///     mem_state — first cut just trusts the handler).
+///   - SCM_RIGHTS: one fd, the memfd.
+///
+/// The handler is expected to seal the memfd (F_SEAL_SHRINK | F_SEAL_GROW)
+/// before sending so Firecracker can rely on its size. Forkd's handler
+/// crate does this.
+fn guest_memory_from_memfd(
+    mem_uds_path: &Path,
+    mem_state: &GuestMemoryState,
+    track_dirty_pages: bool,
+    huge_pages: HugePageConfig,
+) -> Result<GuestMemoryMmap, GuestMemoryFromMemfdError> {
+    use std::os::fd::FromRawFd;
+
+    // Connect to the handler's listening UDS.
+    let socket = UnixStream::connect(mem_uds_path)
+        .map_err(GuestMemoryFromMemfdError::Connect)?;
+
+    // Receive one fd. Use a tiny payload buffer — we don't expect data yet,
+    // just the fd. (vmm_sys_util's recv_with_fds reads at least 1 byte; we
+    // pre-populate a dummy buffer so the call doesn't block waiting for
+    // data.)
+    let mut buf = [0u8; 1];
+    let mut fds = [-1; 1];
+    let (_n_bytes, n_fds) = socket
+        .recv_with_fds(&mut buf, &mut fds)
+        .map_err(GuestMemoryFromMemfdError::RecvFd)?;
+    if n_fds == 0 || fds[0] < 0 {
+        return Err(GuestMemoryFromMemfdError::NoFd);
+    }
+    // SAFETY: the kernel just handed us this fd; it's open and we own it.
+    let memfd = unsafe { File::from_raw_fd(fds[0]) };
+
+    let guest_mem = GuestMemoryMmap::from_external_memfd(
+        &memfd,
+        mem_state,
+        track_dirty_pages,
+        huge_pages,
+    )?;
+    Ok(guest_mem)
+}
+
+// Dispatch in the existing match on MemBackendType. The original match
+// in restore_microvm_from_snapshot() is patched separately — search for
+// `MemBackendType::File` and add a `MemBackendType::Memfd` arm that calls
+// guest_memory_from_memfd. Pseudocode:
+//
+//     match backend_type {
+//         MemBackendType::File => guest_memory_from_file(..),
+//         MemBackendType::Uffd => guest_memory_from_uffd(..),
+//         MemBackendType::Memfd => guest_memory_from_memfd(..)
+//             .map(|m| (m, None)) // no uffd by default; v0.3 will pair
+//                                 // memfd + uffd in a follow-up patch
+//             .map_err(/* into the unified restore error */),
+//     }
+//
+// The exact site is in src/vmm/src/persist.rs::restore_from_snapshot or
+// similar; reading the file at v1.10.1 and finding the existing
+// File/Uffd match is the right move before finalizing this patch.
diff --git a/src/vmm/src/vstate/memory.rs b/src/vmm/src/vstate/memory.rs
index aaaaaaa..bbbbbbb 100644
--- a/src/vmm/src/vstate/memory.rs
+++ b/src/vmm/src/vstate/memory.rs
@@ -225,6 +225,39 @@ impl GuestMemoryExtension for GuestMemoryMmap {
         GuestMemoryMmap::from_regions(regions).map_err(MemoryError::VmMemoryError)
     }

+    /// Creates a GuestMemoryMmap mapping an externally-supplied memfd
+    /// MAP_PRIVATE. Used by forkd v0.3 live-branching to give N children
+    /// kernel-CoW views of the same source memory.
+    ///
+    /// The caller is responsible for:
+    ///   - Creating the memfd (memfd_create + ftruncate + seal).
+    ///   - Ensuring its size matches the sum of region sizes in `state`.
+    ///   - Sending it to Firecracker via the UDS handshake (handled by
+    ///     `guest_memory_from_memfd` in persist.rs).
+    fn from_external_memfd(
+        memfd: &File,
+        state: &GuestMemoryState,
+        track_dirty_pages: bool,
+        huge_pages: HugePageConfig,
+    ) -> Result<Self, MemoryError> {
+        if huge_pages.is_hugetlbfs() {
+            // Same restriction as from_state — hugetlbfs snapshots are
+            // not yet supported.
+            return Err(MemoryError::HugetlbfsSnapshot);
+        }
+        let regions = state
+            .regions
+            .iter()
+            .map(|r| {
+                memfd.try_clone().map(|file_clone| {
+                    let offset = FileOffset::new(file_clone, r.offset);
+                    (offset, GuestAddress(r.base_address), r.size)
+                })
+            })
+            .collect::<Result<Vec<_>, std::io::Error>>()
+            .map_err(MemoryError::FileError)?;
+        Self::from_raw_regions_file(regions, track_dirty_pages, false)
+    }
+
     /// Creates a GuestMemoryMmap from a file.
     fn from_state(
         file: Option<&File>,
